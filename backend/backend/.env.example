# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/adharaedu"

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-key-at-least-32-characters-long"
JWT_EXPIRES_IN="7d"
# Email OTP codes are HMAC’d with JWT_SECRET (see POST /auth/otp/send, /auth/otp/verify).
# In development, the API logs the plaintext OTP to the console when email is sent.

# ── App ──────────────────────────────────────────────────────
PORT=3001
# Comma-separated allowed browser origins for CORS (your Vercel URL + local dev).
# Preview URLs https://*.vercel.app are also allowed unless CORS_ALLOW_VERCEL_PREVIEW=false
FRONTEND_URL="http://localhost:3000"
# CORS_ALLOW_VERCEL_PREVIEW=false

# ── Email ───────────────────────────────────────────────────
# Option A — Resend REST API (recommended): set API key → app uses HTTPS POST api.resend.com
# Verify a domain in Resend, then set RESEND_FROM to e.g. "AdharaEdu <noreply@yourdomain.com>"
RESEND_API_KEY=""
# RESEND_FROM="AdharaEdu <noreply@yourdomain.com>"
#
# Option B — SMTP (Gmail or Resend SMTP): leave RESEND_API_KEY empty and set:
# Gmail: 2FA → App Password
# Resend SMTP: https://resend.com/docs/send-with-nodemailer — smtp.resend.com, user "resend", pass = API key
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="adharaEdu0@gmail.com"
SMTP_PASS="your-gmail-app-password"

# ── Cloudinary (for uploads + certificates) ──────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ── AI (Google Gemini) ──────────────────────────────────────
# Used for drafting CBT questions from module curriculum.
GEMINI_API_KEY=""
# Optional: override model name, e.g. "models/gemini-1.5-flash" or "gemini-2.0-flash"
# You can also provide a comma-separated fallback list (recommended):
# GEMINI_MODEL="gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.5-pro"

# ── Paystack ─────────────────────────────────────────────────
# Get from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY="sk_test_your_paystack_secret_key"
PAYSTACK_PUBLIC_KEY="pk_test_your_paystack_public_key"
