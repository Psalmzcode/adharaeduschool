// AdharaEdu Prisma Schema
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  /// Authors canonical curriculum (tracks/modules/lessons); cannot manage schools or users.
  CURRICULUM_LEAD
  SCHOOL_ADMIN
  TUTOR
  STUDENT
  PARENT
}

enum TrackLevel {
  TRACK_1  // JSS1-SS1: Computer Appreciation
  TRACK_2  // SS1-SS2: Intro to Programming
  TRACK_3  // SS3: Advanced Tech Skills
}

enum SchoolStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

/// Institution type (for onboarding / compliance)
enum SchoolType {
  NURSERY_PRIMARY
  PRIMARY
  SECONDARY
  MIXED
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum ModuleStatus {
  LOCKED
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum AssignmentStatus {
  PENDING
  SUBMITTED
  GRADED
}

enum ExamStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NoticeType {
  URGENT
  IMPORTANT
  INFO
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

enum TutorOnboardingStatus {
  DRAFT // Profile / KYC not finished — limited API access
  COMPLETE
}

/// Email one-time codes (passwordless sign-in, etc.)
enum OtpPurpose {
  SIGN_IN
  /// Verify inbox before creating school admin account (registration flow).
  SCHOOL_REGISTRATION
}

enum TutorIdentificationType {
  NIN
  VOTERS_CARD
  DRIVERS_LICENSE
  INTERNATIONAL_PASSPORT
}

/// Branch for Track 3 modules 3–4 (handbook Stack A vs B). Tutor picks per class assignment; copied to students.
enum Track3Stack {
  PYTHON_FLASK
  REACT_NODE
}

/// Curriculum variant: COMMON = all Track 1–2 modules + Track 3 shared modules (1, 2, 5, 6).
enum ModuleStackVariant {
  COMMON
  PYTHON_FLASK
  REACT_NODE
}

enum ModuleType {
  STANDARD
  /// Term-level \"main exam\" module used to anchor CBT exams that combine multiple modules.
  TERM_EXAM
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  /// Optional for students who sign in with username only; staff/parents typically have email.
  email         String?   @unique
  /// Unique login handle (lowercase). Required for students without a personal email.
  username      String?   @unique
  password      String
  role          Role
  firstName     String
  lastName      String
  phone         String?
  avatarUrl     String?   // Cloudinary URL
  /// Email / push-style alerts (used when notification channels are wired)
  notifyNewMessage      Boolean @default(true)
  notifyReportDeadline  Boolean @default(true)
  notifyExamResults     Boolean @default(false)
  /// When true (typically new students), UI may prompt to change from the default password.
  mustChangePassword    Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  school        School?   @relation("SchoolAdmin", fields: [schoolId], references: [id])
  schoolId      String?
  tutorProfile  Tutor?
  studentProfile Student?
  parentProfile  Parent?
  notifications Notification[]
  sessions      Session[]

  tutorConversations   Conversation[] @relation("TutorConversations")
  tutorSessions        SessionLog[]   @relation("TutorSessions")
  tutorClassAssignments ClassAssignment[] @relation("TutorAssignments")
  lessonPlans          LessonPlan[]   @relation("TutorLessonPlans")
  studentConversations Conversation[] @relation("StudentConversations")
  sentMessages         Message[]      @relation("SentMessages")
  peerMessagesSent     PeerMessage[]  @relation("PeerMessageSender")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model OtpCode {
  id           String     @id @default(cuid())
  email        String
  codeHash     String
  purpose      OtpPurpose @default(SIGN_IN)
  expiresAt    DateTime
  attemptCount Int        @default(0)
  consumedAt   DateTime?
  createdAt    DateTime   @default(now())

  @@index([email, purpose])
  @@map("otp_codes")
}

// ─────────────────────────────────────────────
// SCHOOL
// ─────────────────────────────────────────────

model School {
  id              String        @id @default(cuid())
  name            String
  /// Legal / CAC name (may match `name`)
  officialName    String?
  schoolType      SchoolType?
  code            String        @unique  // e.g. CHR
  address         String
  state           String
  lga             String
  website         String?
  officialEmail   String?
  officialPhone   String?
  principalName   String
  principalPhone  String
  ictContactName  String?
  ictContactPhone String?
  ictContactEmail String?
  billingContactName  String?
  billingContactEmail String?
  billingContactPhone String?
  /// Class levels offered on Adhara (e.g. JSS1, SS2) — free-form checklist
  platformLevels  String[]      @default([])
  logoUrl         String?       // Cloudinary
  status          SchoolStatus  @default(PENDING)
  enrolledTracks  TrackLevel[]
  currentTermLabel   String?
  academicYearLabel  String?
  studentCountBand   String?
  streamsCount       Int?
  /// Internal: tutor visits / site access (not shown to students by default)
  visitDeploymentNotes String?
  timezone        String        @default("Africa/Lagos")
  locale          String        @default("en-NG")
  /// Set when school admin finishes post-approval onboarding (required before full dashboard)
  profileCompletedAt DateTime?
  totalStudents   Int           @default(0)
  feesPerStudent  Float         @default(0)
  contractStart   DateTime?
  contractEnd     DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  admins          User[]        @relation("SchoolAdmin")
  students        Student[]
  tutorAssignments TutorAssignment[]
  notices         Notice[]
  exams           Exam[]
  reports         WeeklyReport[]
  payments        Payment[]

  sessionLogs         SessionLog[]
  payrolls            TutorPayroll[]
  examSchedules       ExamSchedule[]
  classAssignments    ClassAssignment[]
  peerConversations   PeerConversation[]
  classCurriculumStates ClassCurriculumState[]

  @@map("schools")
}

// ─────────────────────────────────────────────
// TUTOR
// ─────────────────────────────────────────────

model Tutor {
  id              String    @id @default(cuid())
  userId          String    @unique
  bio             String?
  specializations String[]  // e.g. ["Python", "HTML/CSS"]
  tracks          TrackLevel[]
  rating          Float     @default(0)
  totalClasses    Int       @default(0)
  isVerified      Boolean   @default(false)
  bankName        String?
  bankAccount     String?
  /// New tutors start DRAFT from API; existing rows default COMPLETE via migration
  onboardingStatus TutorOnboardingStatus @default(COMPLETE)
  passportPhotoUrl String?
  identificationType TutorIdentificationType?
  identificationNumber String?
  identificationDocumentUrl String?
  signatureUrl    String?
  guarantors      Json?     // [{ fullName, phone, email, address, relationship? }, ...]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments     TutorAssignment[]
  reports         WeeklyReport[]
  cbtExams        CBTExam[]

  payrolls  TutorPayroll[]

  @@map("tutors")
}

model TutorAssignment {
  id          String    @id @default(cuid())
  tutorId     String
  schoolId    String
  track       TrackLevel
  className   String    // e.g. "SS3A"
  termLabel   String    // e.g. "2025/2026 Term 2"
  /// Required when track is TRACK_3: which stack the tutor teaches for modules 3–4.
  track3Stack Track3Stack?
  /// Target teaching sessions per week for this class (delivered vs expected reports)
  expectedSessionsPerWeek Int @default(3)
  isActive    Boolean   @default(true)
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime  @default(now())

  tutor       Tutor     @relation(fields: [tutorId], references: [id])
  school      School    @relation(fields: [schoolId], references: [id])
  sessionLogs SessionLog[]

  @@map("tutor_assignments")
}


// ─────────────────────────────────────────────
// STUDENT
// ─────────────────────────────────────────────

model Student {
  id            String      @id @default(cuid())
  userId        String      @unique
  regNumber     String      @unique  // e.g. CHR/2024/SS3A/021
  schoolId      String
  className     String      // e.g. SS3A
  track         TrackLevel
  /// Track 3 only: Python/Flask vs React/Node path — synced from tutor assignment for this class.
  track3Stack   Track3Stack?
  termLabel     String
  parentId      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  school        School      @relation(fields: [schoolId], references: [id])
  parent        Parent?     @relation(fields: [parentId], references: [id])
  moduleProgress ModuleProgress[]
  lessonProgress StudentLessonProgress[]
  attendanceRecords Attendance[]
  examAttempts  ExamAttempt[]
  submissions   AssignmentSubmission[]

  certificates        Certificate[]
  assignmentSubs      ClassAssignmentSubmission[] @relation("StudentAssignmentSubmissions")

  @@map("students")
}

// ─────────────────────────────────────────────
// PARENT
// ─────────────────────────────────────────────

model Parent {
  id        String    @id @default(cuid())
  userId    String    @unique
  notifyBySMS      Boolean @default(true)
  notifyByWhatsApp Boolean @default(true)
  notifyByEmail    Boolean @default(false)
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  children  Student[]

  @@map("parents")
}

// ─────────────────────────────────────────────
// MODULE / CURRICULUM
// ─────────────────────────────────────────────

model Module {
  id          String      @id @default(cuid())
  track       TrackLevel
  number      Int         // Module 1, 2, 3...
  /// Track 3: COMMON for shared modules; PYTHON_FLASK / REACT_NODE for branching modules 3–4 only.
  stackVariant ModuleStackVariant @default(COMMON)
  moduleType  ModuleType  @default(STANDARD)
  /// Only for TERM_EXAM modules: 1, 2, or 3 (maps to the school's termLabel naming).
  termOrdinal Int?
  title       String
  description String
  objectives  String[]
  durationWeeks Int       @default(2)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  progress    ModuleProgress[]
  exams       Exam[]
  assignments Assignment[]
  lessonPlans LessonPlan[]
  cbtExams    CBTExam[]
  practicalTasks PracticalTask[]
  sessionLogs SessionLog[]
  curriculumLessons CurriculumLesson[]

  @@unique([track, number, stackVariant])
  @@map("modules")
}

/// Canonical lesson authored by curriculum (source of truth for delivery).
model CurriculumLesson {
  id                    String   @id @default(cuid())
  moduleId              String
  position              Int      @default(1)
  title                 String
  objective             String?
  /// Timed segments: [{ "label": string, "minutes": number }, ...]
  outline               Json?
  /// Free-form exercise list (strings or structured objects)
  exercises             Json?
  takeHomeTask          String?
  quickCheckQuestions   Json?
  resources             Json?
  estimatedDurationMins Int      @default(60)
  isPublished           Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  module                Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  sessionLogs           SessionLog[]
  lessonPlans           LessonPlan[]
  studentProgress       StudentLessonProgress[]
  classStatesAsCurrent  ClassCurriculumState[] @relation("ClassCurrentLesson")

  @@unique([moduleId, position])
  @@index([moduleId])
  @@map("curriculum_lessons")
}

/// Next lesson the class is scheduled to receive (per school + class + track branch).
model ClassCurriculumState {
  id                    String   @id @default(cuid())
  schoolId              String
  className             String
  /// e.g. TRACK_1, TRACK_2, TRACK_3_PYTHON_FLASK (see curriculum-branch helper)
  curriculumBranchKey   String
  currentLessonId       String?
  updatedAt             DateTime @updatedAt

  school                School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  currentLesson         CurriculumLesson? @relation("ClassCurrentLesson", fields: [currentLessonId], references: [id], onDelete: SetNull)

  @@unique([schoolId, className, curriculumBranchKey])
  @@index([schoolId, className])
  @@map("class_curriculum_state")
}

model StudentLessonProgress {
  id              String    @id @default(cuid())
  studentId       String
  lessonId        String
  sessionId       String?
  completed       Boolean   @default(false)
  quickCheckScore Float?
  exerciseScores  Json?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson          CurriculumLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  session         SessionLog? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@unique([studentId, lessonId])
  @@index([lessonId])
  @@map("student_lesson_progress")
}

model ModuleProgress {
  id          String        @id @default(cuid())
  studentId   String
  moduleId    String
  /// Term label at the time this progress row was created (for termly reporting/billing)
  termLabel   String?
  status      ModuleStatus  @default(LOCKED)
  score       Float?
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  module      Module        @relation(fields: [moduleId], references: [id])

  @@unique([studentId, moduleId])
  @@map("module_progress")
}

// ─────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────

model Attendance {
  id          String            @id @default(cuid())
  studentId   String
  date        DateTime          @db.Date
  /// Term label captured when attendance was recorded
  termLabel   String?
  status      AttendanceStatus  @default(PRESENT)
  notes       String?
  markedBy    String?           // tutorId
  createdAt   DateTime          @default(now())

  student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@map("attendance")
}

// ─────────────────────────────────────────────
// ASSIGNMENT
// ─────────────────────────────────────────────

model Assignment {
  id          String    @id @default(cuid())
  moduleId    String
  title       String
  description String
  dueDate     DateTime
  attachmentUrl String? // Cloudinary
  createdAt   DateTime  @default(now())

  module      Module    @relation(fields: [moduleId], references: [id])
  submissions AssignmentSubmission[]

  @@map("assignments")
}

model AssignmentSubmission {
  id            String            @id @default(cuid())
  assignmentId  String
  studentId     String
  status        AssignmentStatus  @default(SUBMITTED)
  fileUrl       String?           // Cloudinary
  notes         String?
  grade         Float?
  feedback      String?
  submittedAt   DateTime          @default(now())
  gradedAt      DateTime?

  assignment    Assignment        @relation(fields: [assignmentId], references: [id])
  student       Student           @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
  @@map("assignment_submissions")
}

// ─────────────────────────────────────────────
// CBT EXAM
// ─────────────────────────────────────────────

model CBTExam {
  id            String      @id @default(cuid())
  tutorId       String
  moduleId      String
  title         String
  description   String?
  track         TrackLevel
  durationMins  Int         @default(30)
  totalQuestions Int        @default(15)
  passScore     Float       @default(50)
  isPublished   Boolean     @default(false)
  isVetted      Boolean     @default(false)  // Super admin vetting
  scheduledFor  DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tutor         Tutor       @relation(fields: [tutorId], references: [id])
  module        Module      @relation(fields: [moduleId], references: [id])
  questions     CBTQuestion[]
  attempts      ExamAttempt[]
  exams         Exam[]

  schedules  ExamSchedule[]

  @@map("cbt_exams")
}

model CBTQuestion {
  id          String    @id @default(cuid())
  examId      String
  number      Int
  questionText String
  options     String[]  // Array of 4 options
  correctIndex Int      // 0-3
  explanation  String?
  imageUrl    String?   // Cloudinary

  exam        CBTExam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, number])
  @@map("cbt_questions")
}

model ExamAttempt {
  id            String      @id @default(cuid())
  cbtExamId     String
  studentId     String
  examId        String?
  /// When the attempt was started from a scheduled exam (My Exams / login-schedule).
  examScheduleId String?
  /// Term label captured when the attempt was started
  termLabel     String?
  answers       Json        // { questionIndex: selectedOption }
  score         Float?
  totalCorrect  Int?
  timeTaken     Int?        // seconds
  status        ExamStatus  @default(IN_PROGRESS)
  startedAt     DateTime    @default(now())
  submittedAt   DateTime?

  cbtExam       CBTExam     @relation(fields: [cbtExamId], references: [id])
  student       Student     @relation(fields: [studentId], references: [id])
  exam          Exam?       @relation(fields: [examId], references: [id])
  examSchedule  ExamSchedule? @relation(fields: [examScheduleId], references: [id], onDelete: SetNull)

  @@map("exam_attempts")
}

// ─────────────────────────────────────────────
// SCHEDULED EXAM (calendar)
// ─────────────────────────────────────────────

model Exam {
  id          String    @id @default(cuid())
  schoolId    String
  moduleId    String
  cbtExamId   String?
  title       String
  scheduledAt DateTime
  venue       String?
  status      ExamStatus @default(SCHEDULED)
  createdAt   DateTime   @default(now())

  school      School     @relation(fields: [schoolId], references: [id])
  module      Module     @relation(fields: [moduleId], references: [id])
  cbtExam     CBTExam?   @relation(fields: [cbtExamId], references: [id])
  attempts    ExamAttempt[]

  @@map("exams")
}

// ─────────────────────────────────────────────
// WEEKLY REPORT
// ─────────────────────────────────────────────

model WeeklyReport {
  id              String        @id @default(cuid())
  tutorId         String
  schoolId        String
  weekStart       DateTime      @db.Date
  weekEnd         DateTime      @db.Date
  track           TrackLevel
  className       String
  topicsCoins     String[]      // Topics covered
  attendanceRate  Float
  highlights      String?
  challenges      String?
  nextWeekPlan    String?
  status          ReportStatus  @default(DRAFT)
  submittedAt     DateTime?
  reviewedBy      String?
  reviewNotes     String?
  attachmentUrl   String?       // Cloudinary
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tutor           Tutor         @relation(fields: [tutorId], references: [id])
  school          School        @relation(fields: [schoolId], references: [id])

  @@map("weekly_reports")
}

// ─────────────────────────────────────────────
// NOTICE
// ─────────────────────────────────────────────

model Notice {
  id        String      @id @default(cuid())
  schoolId  String
  title     String
  body      String
  type      NoticeType  @default(INFO)
  publishedAt DateTime  @default(now())
  expiresAt DateTime?
  createdBy String

  school    School      @relation(fields: [schoolId], references: [id])

  @@map("notices")
}

// ─────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────

model Payment {
  id            String    @id @default(cuid())
  schoolId      String
  amount        Float
  description   String
  receiptUrl    String?   // Cloudinary
  paidAt        DateTime?
  isPaid        Boolean   @default(false)
  termLabel     String
  createdAt     DateTime  @default(now())

  school        School    @relation(fields: [schoolId], references: [id])

  transactions  PaystackTransaction[]

  @@map("payments")
}

// ─────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean   @default(false)
  link      String?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─────────────────────────────────────────────
// UPLOAD RECORD
// ─────────────────────────────────────────────

model Upload {
  id          String    @id @default(cuid())
  publicId    String    @unique  // Cloudinary public_id
  url         String
  resourceType String
  uploadedBy  String
  entityType  String    // "avatar", "assignment", "report", "receipt"
  entityId    String?
  createdAt   DateTime  @default(now())

  @@map("uploads")
}

// ─────────────────────────────────────────────
// MESSAGES (tutor ↔ student direct messaging)
// ─────────────────────────────────────────────

model Conversation {
  id          String    @id @default(cuid())
  tutorId     String
  studentId   String
  schoolId    String
  lastMessage String?
  lastAt      DateTime  @default(now())
  createdAt   DateTime  @default(now())

  tutor     User      @relation("TutorConversations",   fields: [tutorId],   references: [id])
  student   User      @relation("StudentConversations", fields: [studentId], references: [id])
  messages  Message[]

  @@unique([tutorId, studentId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  conversation  Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender        User          @relation("SentMessages", fields: [senderId], references: [id])

  @@map("messages")
}

// Student ↔ student (same class) direct messages — separate from tutor ↔ student Conversation
model PeerConversation {
  id           String   @id @default(cuid())
  schoolId     String
  userLowerId  String
  userHigherId String
  lastMessage  String?
  lastAt       DateTime @default(now())
  createdAt    DateTime @default(now())

  school   School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  messages PeerMessage[]

  @@unique([userLowerId, userHigherId])
  @@map("peer_conversations")
}

model PeerMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation PeerConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User             @relation("PeerMessageSender", fields: [senderId], references: [id])

  @@map("peer_messages")
}

// ─────────────────────────────────────────────
// LESSON PLANS
// ─────────────────────────────────────────────

model LessonPlan {
  id          String   @id @default(cuid())
  tutorId     String
  schoolId    String
  className   String
  moduleId    String
  /// Optional link to canonical curriculum lesson (tutor prep still lives in `steps`).
  curriculumLessonId String?
  title       String
  durationMins Int     @default(75)
  venue       String?
  scheduledAt DateTime?
  steps       Json     // Array of {title, desc, color}
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tutor User @relation("TutorLessonPlans", fields: [tutorId], references: [id])
  module Module @relation(fields: [moduleId], references: [id])
  curriculumLesson CurriculumLesson? @relation(fields: [curriculumLessonId], references: [id], onDelete: SetNull)

  @@map("lesson_plans")
}

// ─────────────────────────────────────────────
// CERTIFICATES
// ─────────────────────────────────────────────

model Certificate {
  id           String   @id @default(cuid())
  studentId    String
  track        String
  serialNumber String   @unique
  pdfUrl       String?
  qrCode       String?
  averageScore Float
  issueDate    DateTime @default(now())
  expiryDate   DateTime?
  isRevoked    Boolean  @default(false)

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

// ─────────────────────────────────────────────
// SESSION LOGS (tutor accountability)
// ─────────────────────────────────────────────

model SessionLog {
  id                  String   @id @default(cuid())
  tutorId             String
  schoolId            String
  className           String
  track               String
  moduleTitle         String?
  /// Term label captured when the session started (for termly activity reporting)
  termLabel           String?
  /// Links to tutor ↔ school ↔ class row for reporting (optional for legacy rows)
  tutorAssignmentId   String?
  /// Curriculum module taught this session (track must match class)
  moduleId            String?
  /// Canonical lesson delivered this session (required when the module has published lessons)
  lessonId            String?
  startedAt           DateTime @default(now())
  endedAt             DateTime?
  durationMins        Int?
  studentsPresent     Int      @default(0)
  notes               String?

  tutor             User              @relation("TutorSessions", fields: [tutorId], references: [id])
  school            School            @relation(fields: [schoolId], references: [id])
  tutorAssignment   TutorAssignment?  @relation(fields: [tutorAssignmentId], references: [id], onDelete: SetNull)
  module            Module?           @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  lesson            CurriculumLesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  studentLessonProgress StudentLessonProgress[]

  @@index([tutorAssignmentId])
  @@index([moduleId])
  @@index([lessonId])
  @@map("session_logs")
}

// ─────────────────────────────────────────────
// PAYROLL
// ─────────────────────────────────────────────

model TutorPayroll {
  id             String   @id @default(cuid())
  tutorId        String
  schoolId       String
  month          Int
  year           Int
  totalSessions  Int      @default(0)
  ratePerSession Float    @default(0)
  grossAmount    Float    @default(0)
  deductions     Float    @default(0)
  netAmount      Float    @default(0)
  isPaid         Boolean  @default(false)
  paidAt         DateTime?
  notes          String?
  reportIds      String[]
  createdAt      DateTime @default(now())

  tutor  Tutor  @relation(fields: [tutorId], references: [id])
  school School @relation(fields: [schoolId], references: [id])

  @@unique([tutorId, schoolId, month, year])
  @@map("tutor_payroll")
}

// ─────────────────────────────────────────────
// EXAM ↔ CLASS ASSIGNMENT
// ─────────────────────────────────────────────

model ExamSchedule {
  id           String     @id @default(cuid())
  cbtExamId    String
  schoolId     String
  className    String
  scheduledAt  DateTime
  venue        String?
  durationMins Int        @default(30)
  status       ExamStatus @default(SCHEDULED)
  createdBy    String
  accessCode   String     @default("")
  isActive     Boolean    @default(true)
  /// When true, students see "submitted" but not score until `resultsReleasedAt` is set.
  awaitTutorResultRelease Boolean @default(false)
  /// Tutor (or admin) marks results visible for the class.
  resultsReleasedAt      DateTime?
  createdAt    DateTime   @default(now())

  cbtExam CBTExam @relation(fields: [cbtExamId], references: [id])
  school  School  @relation(fields: [schoolId],  references: [id])
  attempts ExamAttempt[]

  @@map("exam_schedules")
}


// ─────────────────────────────────────────────
// PAYSTACK PAYMENT TRANSACTIONS
// ─────────────────────────────────────────────
model PaystackTransaction {
  id            String   @id @default(cuid())
  paymentId     String
  reference     String   @unique
  amount        Float
  currency      String   @default("NGN")
  status        String   @default("pending")  // pending | success | failed
  channel       String?  // card | bank_transfer | ussd
  paidAt        DateTime?
  metadata      Json?
  createdAt     DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])

  @@map("paystack_transactions")
}

// ─────────────────────────────────────────────
// ASSIGNMENTS (tutor-created homework)
// ─────────────────────────────────────────────

// ─────────────────────────────────────────────
// ASSIGNMENTS (tutor-created homework)
// ─────────────────────────────────────────────
model ClassAssignment {
  id           String   @id @default(cuid())
  tutorId      String
  schoolId     String
  className    String
  moduleId     String?
  title        String
  description  String
  dueDate      DateTime
  attachmentUrl String?
  maxScore     Int      @default(100)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())

  tutor         User                       @relation("TutorAssignments", fields: [tutorId], references: [id])
  school        School                     @relation(fields: [schoolId], references: [id])
  submissions   ClassAssignmentSubmission[]

  @@map("class_assignments")
}

model ClassAssignmentSubmission {
  id             String   @id @default(cuid())
  assignmentId   String
  studentId      String
  /// Term label captured when the submission was created
  termLabel      String?
  fileUrl        String?
  textBody       String?
  score          Float?
  feedback       String?
  status         String   @default("SUBMITTED")  // SUBMITTED | GRADED | LATE
  submittedAt    DateTime @default(now())
  gradedAt       DateTime?

  assignment ClassAssignment @relation(fields: [assignmentId], references: [id])
  student    Student         @relation("StudentAssignmentSubmissions", fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
  @@map("class_assignment_submissions")
}

model PracticalTask {
  id           String   @id @default(cuid())
  tutorId      String
  schoolId     String
  className    String
  moduleId     String
  title        String
  description  String?
  instructions String?
  dueDate      DateTime?
  maxScore     Int      @default(100)
  passScore    Float    @default(50)
  rubric       Json?
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  module      Module               @relation(fields: [moduleId], references: [id])
  submissions PracticalSubmission[]

  @@index([schoolId, className, moduleId])
  @@map("practical_tasks")
}

model PracticalSubmission {
  id             String   @id @default(cuid())
  taskId         String
  studentId      String
  /// Term label captured when the submission was created
  termLabel      String?
  evidenceUrl    String?
  evidenceText   String?
  scoreBreakdown Json?
  totalScore     Float?
  feedback       String?
  status         String   @default("SUBMITTED")
  submittedAt    DateTime @default(now())
  gradedAt       DateTime?
  gradedBy       String?

  task PracticalTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, studentId])
  @@index([studentId])
  @@map("practical_submissions")
}
